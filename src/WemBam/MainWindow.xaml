<Window x:Class="WemBam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wem Bam"
        Height="900"
        Width="1500"
        MinHeight="700"
        MinWidth="1100">

	<DockPanel>

		<!-- Top Menu -->
		<Menu DockPanel.Dock="Top">
			<MenuItem Header="_File">
				<MenuItem Header="Settings..."
                          Click="SettingsMenuItem_Click"/>
				<Separator/>
				<MenuItem Header="E_xit"/>
			</MenuItem>

			<MenuItem Header="_View"/>

			<MenuItem Header="_Help"/>
		</Menu>

		<!-- Status Bar -->
		<StatusBar DockPanel.Dock="Bottom">

			<StatusBar.ToolTip>
				<ToolTip x:Name="BackgroundTaskToolTip">
					<StackPanel>

						<TextBlock x:Name="StatusToolTipStatusText"/>

						<TextBlock x:Name="StatusToolTipItemsProcessedText"/>

						<TextBlock x:Name="StatusToolTipTotalItemsText"/>

						<TextBlock x:Name="StatusToolTipElapsedText"/>

					</StackPanel>
				</ToolTip>
			</StatusBar.ToolTip>

			<StatusBarItem>

				<Grid>

					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<TextBlock x:Name="StatusTextBlock"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="Ready"/>

					<ProgressBar x:Name="BackgroundTaskProgressBar"
                                 Grid.Column="1"
                                 Height="16"
                                 Margin="12,0"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 IsIndeterminate="False"
                                 Visibility="Collapsed"/>

					<TextBlock x:Name="PercentageTextBlock"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Text=""
                               Visibility="Collapsed"/>

					<TextBlock x:Name="ElapsedTimeTextBlock"
                               Grid.Column="3"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Text=""/>

				</Grid>

			</StatusBarItem>

		</StatusBar>

		<!-- Playback -->
		<Border DockPanel.Dock="Bottom"
                BorderBrush="#FFD8D8D8"
                BorderThickness="0,1,0,0"
                Padding="8">

			<Grid>

				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="16"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="20"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="140"/>
				</Grid.ColumnDefinitions>

				<!-- Transport -->
				<StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

					<Button Content="Previous"
                            Margin="0,0,6,0"
                            MinWidth="75"/>

					<Button Content="Play / Pause"
                            Margin="0,0,6,0"
                            MinWidth="95"/>

					<Button Content="Next"
                            Margin="0,0,6,0"
                            MinWidth="60"/>

					<Button Content="Stop"
                            MinWidth="60"/>

				</StackPanel>

				<!-- Timeline -->
				<Slider Grid.Column="2"
                        VerticalAlignment="Center"/>

				<!-- Volume -->
				<TextBlock Grid.Column="4"
                           Text="Volume"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

				<Slider Grid.Column="5"
                        VerticalAlignment="Center"/>

			</Grid>

		</Border>

		<!-- Main Area -->
		<Grid Margin="8">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="4*"/>
				<ColumnDefinition Width="5"/>
				<ColumnDefinition Width="320"
                                  MinWidth="280"/>
			</Grid.ColumnDefinitions>

			<!-- Workspace -->
			<TabControl Grid.Column="0">

				<TabItem Header="Filter 1">

					<Grid Margin="6">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="250"
                                              MinWidth="200"/>
							<ColumnDefinition Width="5"/>
							<ColumnDefinition Width="*"
                                              MinWidth="450"/>
						</Grid.ColumnDefinitions>

						<!-- Collections -->
						<GroupBox Grid.Column="0"
                                  Header="Collections"
                                  Margin="0,0,6,0">

							<Grid Margin="6">

								<Grid.RowDefinitions>
									<RowDefinition Height="*"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<TreeView Grid.Row="0">

									<TreeViewItem Header="All Sounds"/>

									<TreeViewItem Header="Favourites"/>

									<TreeViewItem Header="Collections">
										<TreeViewItem Header="Example Collection"/>
									</TreeViewItem>

								</TreeView>

								<StackPanel Grid.Row="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            Margin="0,8,0,0">

									<Button Content="New"
                                            Width="70"/>

									<Button Content="Rename"
                                            Width="75"
                                            Margin="6,0,0,0"/>

									<Button Content="Delete"
                                            Width="70"
                                            Margin="6,0,0,0"/>

								</StackPanel>

							</Grid>

						</GroupBox>

						<!-- Splitter -->
						<GridSplitter Grid.Column="1"
                                      Width="5"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Stretch"
                                      Background="Transparent"
                                      ShowsPreview="True"
                                      ResizeBehavior="PreviousAndNext"/>

						<!-- Results -->
						<Grid Grid.Column="2"
                              Margin="6,0,0,0">

							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="8"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<!-- Filter -->
							<Grid Grid.Row="0">

								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="10"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>

								<Label Grid.Column="0"
                                       Content="Filter"
                                       VerticalAlignment="Center"
                                       Padding="0"/>

								<TextBox Grid.Column="2"
                                         VerticalAlignment="Center"
                                         MinWidth="150"/>

							</Grid>

							<!-- Results -->
							<DataGrid Grid.Row="2"
                                      MinWidth="450"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column">

								<DataGrid.Columns>

									<DataGridTextColumn Header="Filename"
                                                        Width="2*"/>

									<DataGridTextColumn Header="Path"
                                                        Width="3*"/>

									<DataGridTextColumn Header="File ID"
                                                        Width="120"/>

								</DataGrid.Columns>

							</DataGrid>

						</Grid>

					</Grid>

				</TabItem>

				<TabItem Header="+"/>

			</TabControl>

			<!-- Main Splitter -->
			<GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"/>

			<!-- Details -->
			<GroupBox Grid.Column="2"
                      Header="Selected Sound"
                      Margin="6,0,0,0"
                      MinWidth="280">

				<ScrollViewer VerticalScrollBarVisibility="Auto">

					<StackPanel Margin="10">

						<TextBlock Text="Filename"
                                   FontWeight="SemiBold"/>

						<TextBox IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Margin="0,1,0,8"
                                 Padding="0"/>

						<TextBlock Text="Path"
                                   FontWeight="SemiBold"/>

						<TextBox IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 HorizontalScrollBarVisibility="Auto"
                                 Margin="0,1,0,8"
                                 Padding="0"/>

						<TextBlock Text="File ID"
                                   FontWeight="SemiBold"/>

						<TextBox IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Margin="0,1,0,10"
                                 Padding="0"/>

						<Separator Margin="0,2,0,8"/>

						<TextBlock Text="Tags"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>

						<ListBox Height="100"/>

						<Separator Margin="0,8"/>

						<TextBlock Text="Notes"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>

						<TextBox Height="180"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"/>

					</StackPanel>

				</ScrollViewer>

			</GroupBox>

		</Grid>

	</DockPanel>

</Window>