<Window x:Class="WemBam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wem Bam"
        Height="900"
        Width="1500"
        MinHeight="700"
        MinWidth="1100">

	<DockPanel>

		<!-- Top Menu -->
		<Menu DockPanel.Dock="Top">
			<MenuItem Header="_File"/>
			<MenuItem Header="_View"/>
			<MenuItem Header="_Help"/>
		</Menu>

		<!-- Bottom Playback -->
		<Border DockPanel.Dock="Bottom"
                BorderThickness="1,1,1,0"
                BorderBrush="Gainsboro"
                Padding="8">

			<StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">

				<Button Content="⏮"
                        Width="36"
                        Margin="0,0,6,0"/>

				<Button Content="▶"
                        Width="50"
                        Margin="0,0,6,0"/>

				<Button Content="⏸"
                        Width="50"
                        Margin="0,0,6,0"/>

				<Button Content="⏹"
                        Width="50"
                        Margin="0,0,16,0"/>

				<Slider Width="250"
                        Margin="0,0,12,0"/>

				<TextBlock Text="00:00 / 00:00"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

				<TextBlock Text="Volume"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

				<Slider Width="120"/>
			</StackPanel>

		</Border>

		<!-- Status Bar -->
		<StatusBar DockPanel.Dock="Bottom">
			<StatusBarItem Content="Ready"/>
		</StatusBar>

		<!-- Main Content -->
		<Grid Margin="8">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="4*"/>
				<ColumnDefinition Width="5"/>
				<ColumnDefinition Width="320"/>
			</Grid.ColumnDefinitions>

			<!-- Main Workspace -->
			<TabControl Grid.Column="0">

				<TabItem Header="Filter 1">

					<Grid Margin="6">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="250"/>
							<ColumnDefinition Width="5"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<!-- Collection Browser -->
						<GroupBox Grid.Column="0"
                                  Header="Collection Browser"
                                  Margin="0,0,6,0">

							<Grid Margin="6">

								<Grid.RowDefinitions>
									<RowDefinition Height="*"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<TreeView Grid.Row="0">

									<TreeViewItem Header="All Sounds"/>

									<TreeViewItem Header="Favourites"/>

									<TreeViewItem Header="Collections">
										<TreeViewItem Header="Example Collection"/>
									</TreeViewItem>

								</TreeView>

								<ToolBar Grid.Row="1"
                                         Margin="0,8,0,0">

									<Button Content="New"/>
									<Button Content="Rename"/>
									<Button Content="Delete"/>

								</ToolBar>

							</Grid>

						</GroupBox>

						<GridSplitter Grid.Column="1"
                                      Width="5"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      ResizeBehavior="PreviousAndNext"
                                      Background="Transparent"/>

						<!-- Results Area -->
						<Grid Grid.Column="2"
                              Margin="6,0,0,0">

							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,8">

								<Label Content="Filter"
                                       VerticalAlignment="Center"/>

								<TextBox Width="300"
                                         Margin="8,0,0,0"/>

							</StackPanel>

							<DataGrid Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True">

								<DataGrid.Columns>

									<DataGridTextColumn Header="Filename"
                                                        Width="2*"/>

									<DataGridTextColumn Header="Path"
                                                        Width="3*"/>

									<DataGridTextColumn Header="File ID"
                                                        Width="120"/>

								</DataGrid.Columns>

							</DataGrid>

						</Grid>

					</Grid>

				</TabItem>

			</TabControl>

			<!-- Splitter -->
			<GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          Background="Transparent"/>

			<!-- Selected Sound Panel -->
			<GroupBox Grid.Column="2"
                      Header="Selected Sound"
                      Margin="6,0,0,0">

				<ScrollViewer VerticalScrollBarVisibility="Auto">

					<StackPanel Margin="10">

						<TextBlock Text="Filename:"
                                   FontWeight="Bold"/>

						<TextBlock Text="—"
                                   Margin="0,0,0,12"/>

						<TextBlock Text="Path:"
                                   FontWeight="Bold"/>

						<TextBlock Text="—"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

						<TextBlock Text="File ID:"
                                   FontWeight="Bold"/>

						<TextBlock Text="—"
                                   Margin="0,0,0,12"/>

						<Separator Margin="0,4"/>

						<TextBlock Text="Tags"
                                   FontWeight="Bold"
                                   Margin="0,8,0,6"/>

						<ListBox Height="100"/>

						<Separator Margin="0,10"/>

						<TextBlock Text="Notes"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>

						<TextBox Height="180"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"/>

					</StackPanel>

				</ScrollViewer>

			</GroupBox>

		</Grid>

	</DockPanel>

</Window>